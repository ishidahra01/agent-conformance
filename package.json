{
  "name": "agent-conformance",
  "version": "0.1.0",
  "description": "Verify how coding agents behave against repo-level instructions, skills, MCP config, and policy",
  "main": "dist/index.js",
  "bin": {
    "agent-conformance": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "cli": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "conformance",
    "claude",
    "codex",
    "testing",
    "verification",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "winston": "^3.11.0",
    "yaml": "^2.3.4",
    "glob": "^10.3.10",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "ts-jest": "^29.1.1"
  }
}
